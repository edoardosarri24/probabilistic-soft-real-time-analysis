
classDiagram

    class BernsteinOperator {
        <<static>>
        + fromFunction(Function f, int n, double supportMin, double supportMax) BernsteinPolynomial
    }

    %% Domain classes
    class BernsteinPolynomial {
        <<final>>
        - double[] coefficients
        - BernsteinBasis basis
        - double supportMin
        - double supportMax
        + evaluate(double x) double
        + derivative() BernsteinPolynomial
        + getCoefficients() double[]
    }

    class BernsteinBasis {
        <<interface>>
        + eval(int i, int n, double x) double
    }

    class StandardBernsteinBasis {
        <<final>>
    }

    class ExponentialBernsteinBasis {
        <<final>>
        - double lambda
    }

    %% Relations
    BernsteinPolynomial o-- BernsteinBasis
    BernsteinBasis <|-- StandardBernsteinBasis
    BernsteinBasis <|-- ExponentialBernsteinBasis
    BernsteinOperator ..> BernsteinPolynomial
