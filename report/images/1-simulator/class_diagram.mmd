classDiagram

    %% Scheduler
    class Scheduler {
        <<abstract>>
        - taskSet : TaskSet
        - clock : MyClock
        - simulationDuration : Duration
        - logger : TraceLogger
        + analyze() : void
    }

    class FixedPriorityScheduler {
        <<abstract>>
        + analyze() : void
        # assignPriority() : void
    }

    class DMScheduler {
        <<final>>
        # assignPriority() : void
    }

    %% TaskSet
    class TaskSet {
        <<final>>
        - tasks : Set~Task~
    }

    class Task {
        <<final>>
        - periodSampler : Sampler
        - deadline : Duration
        - executionTimeSampler : Sampler
        - firstReleaseTime : Duration
        - priority : int
        + sampleNextPeriod() : Duration
        + releaseJob(Duration releaseTime) : Job
    }

    class Job {
        <<final>>
        - task : Task
        - absoluteDeadline : Duration
        + execute(Duration durationAvailable) : Duration
        + isDeadlineMissed(Duration currentTime) : boolean
    }

    %% Event
    class Event {
        <<abstract>>
        - time : Duration
    }

    class ReleaseEvent {
        <<final>>
        - task : Task
    }

    class DeadlineEvent {
        <<final>>
        -job : Job
    }

    %% Logger
    class MyTraceLogger {
        <<interface>>
        + log(String message) : void
        + close() : void
    }

    class TraceLogger {
        <<final>>
        + log(String message) : void
        + close() : void
    }

    class NoTraceLogger {
        <<final>>
        + log(String message) : void
        + close() : void
    }

    %% Sampler
    class Sampler {
        <<interface>>
        +getSample() : BigDecimal
    }

    class DeterministicSampler {
        <<final>>
        - value : BigDecimal
        + getSample() : BigDecimal
    }

    class DiscreteChoiceSampler {
        <<final>>
        - values : List~BigDecimal~
        - probabilities : List~Double~
        + getSample() : BigDecimal
    }

    %% Utils
    class MyClock {
        <<final>>
        - currentTime : Duration
        + advanceTo(Duration newTime) : void
        + advanceBy(Duration delta) : void
        + printCurrentTime() : String
        + reset() : void
    }

    class TaskExecutionTimeCollector{
        <<final>>
        - taskExecutionTime : Map~Task,ListDuration~
    }

    class AbortedJobsCollector{
        <<final>>
        - abortedJobs : Map~Task,ListJob~
        - jobPerTaskReleased : Map~Task,Integer~
    }

    %% Relationships
    Client --> Scheduler : analyse()
    %% Scheduler
    Scheduler <|-- FixedPriorityScheduler
    FixedPriorityScheduler <|-- DMScheduler
    Scheduler --> MyClock
    Scheduler --> MyTraceLogger
    Scheduler --> TaskExecutionTimeCollector
    Scheduler --> AbortedJobsCollector
    FixedPriorityScheduler o-- TaskSet
    FixedPriorityScheduler o-- Event : eventQueue
    Scheduler ..> DeadlineMissedException : throws
    %% TaskSet
    TaskSet *-- Task
    Job o-- Task
    Task o-- Sampler : periodSampler
    Task o-- Sampler : executionTimeSampler
    Task ..> Job : releaseJob
    %% Event
    Event <|-- ReleaseEvent
    Event <|-- DeadlineEvent
    %% Logger
    MyTraceLogger <|.. TraceLogger
    MyTraceLogger <|.. NoTraceLogger
    %% Sampler
    Sampler <|.. DeterministicSampler
    Sampler <|.. DiscreteChoiceSampler