stateDiagram-v2
    [*] --> Initialization

    state Initialization {
        PriorityAssignment: Assign priorities according to scheduling policy.
        StateReset: Reset global clock, collectors, and internal state.
        Bootstrapping: Release the first job for each task.
        PriorityAssignment --> StateReset
        StateReset --> Bootstrapping
    }

    state "Main Simulation Loop" as MainLoop {
        CheckDuration: Check if next event time is within duration.
        state DurationCheck <<choice>>

        CalculateInterval: Calculate available time until next event.
        DistributeLoad: Distribute available time among ready jobs by priority.
        Synchronization: Align clock with event time and verify deadlines.
        EventHandling: Process simultaneous events and release new jobs.

        [*] --> CheckDuration
        CheckDuration --> DurationCheck
        DurationCheck --> [*] : Duration Exceeded
        DurationCheck --> CalculateInterval : Continue
        CalculateInterval --> DistributeLoad
        DistributeLoad --> Synchronization
        Synchronization --> EventHandling
        EventHandling --> CheckDuration
    }

    Initialization --> MainLoop